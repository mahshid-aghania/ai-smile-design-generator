# Replicate (required for /api/generate-smile)
# Create a token at https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# Replicate model slug (default: black-forest-labs/flux-kontext-max)
# flux-kontext-max expects: prompt, input_image (URL), aspect_ratio, optional seed — see lib/replicate-smile.ts
REPLICATE_MODEL=black-forest-labs/flux-kontext-max

# Optional (demo): HTTPS URL to POST { patient, treatmentId, previewImageUrl, submittedAt } after success.
PATIENT_INTAKE_WEBHOOK_URL=
